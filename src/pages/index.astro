  <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <script type="text/javascript">
    (function() {
      // NOTE TO USER: Replace with your actual EmailJS Public Key
      emailjs.init({
        publicKey: "w1vGB5KJ-qhOdQCRh",
      });
    })();
  </script>
  <script is:inline>
    (function() {
      document.documentElement.classList.add('js-anim');
      var nodes = Array.prototype.slice.call(document.querySelectorAll('.section-animate'));
      if (!nodes.length) return;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
        nodes.forEach(function(node) {
          node.classList.add('in-view');
        });
        return;
      }

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.24, rootMargin: '0px 0px -8% 0px' });

      nodes.forEach(function(node) {
        observer.observe(node);
      });

      // Contact Buttons Inline Toggle
      var btnEmail = document.getElementById('btn-email');
      var btnCall = document.getElementById('btn-call');
      var inlineEmail = document.getElementById('inline-email');
      var inlineCall = document.getElementById('inline-call');

      if (btnEmail && inlineEmail) {
        btnEmail.addEventListener('click', function() {
          inlineEmail.classList.toggle('active');
          inlineCall.classList.remove('active');
        });
      }

      if (btnCall && inlineCall) {
        btnCall.addEventListener('click', function() {
          inlineCall.classList.toggle('active');
          inlineEmail.classList.remove('active');
        });
      }

      // Modal Logic
      var modal = document.getElementById('project-modal');
      var closeBtn = document.querySelector('.close-modal');
      var projectItems = document.querySelectorAll('.interactive-project');

      if (modal && closeBtn) {
        closeBtn.addEventListener('click', function() {
          modal.classList.remove('open');
          setTimeout(function() { modal.close(); }, 250); 
        });

        modal.addEventListener('click', function(e) {
          var rect = modal.getBoundingClientRect();
          if (e.clientX < rect.left || e.clientX > rect.right || e.clientY < rect.top || e.clientY > rect.bottom) {
            modal.classList.remove('open');
            setTimeout(function() { modal.close(); }, 250);
          }
        });

        projectItems.forEach(function(item) {
          item.addEventListener('click', function() {
            document.getElementById('modal-title').textContent = item.getAttribute('data-title');
            document.getElementById('modal-desc').textContent = item.getAttribute('data-desc');
            document.getElementById('modal-link').href = item.getAttribute('data-link');
            
            var featuresList = document.getElementById('modal-features');
            featuresList.innerHTML = '';
            var features = JSON.parse(item.getAttribute('data-features') || '[]');
            features.forEach(function(feat) {
              var li = document.createElement('li');
              li.textContent = feat;
              featuresList.appendChild(li);
            });
            
            modal.showModal();
            modal.classList.add('open');
          });

          // Allow keyboard activation (Enter/Space)
          item.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              item.click();
            }
          });
        });
      }

      // Contact Form Logic
      var contactForm = document.getElementById('contact-form');
      var submitBtn = document.getElementById('submit-btn');
      var formStatus = document.getElementById('form-status');

      if (contactForm && submitBtn) {
        contactForm.addEventListener('submit', function(e) {
          e.preventDefault();
          
          var emailVal = document.getElementById('user_email').value;
          // Minimal regex for client email validation before attempting to send
          if (!/^\S+@\S+\.\S+$/.test(emailVal)) {
            formStatus.textContent = 'Please enter a valid email format.';
            formStatus.className = 'form-status error';
            return;
          }

          submitBtn.textContent = 'Sending...';
          submitBtn.disabled = true;

          // Real EmailJS Integration
          emailjs.sendForm('service_m9ckz7p', 'template_6b9ry75', contactForm)
            .then(function() {
              formStatus.textContent = 'Message sent successfully!';
              formStatus.className = 'form-status success';
              submitBtn.textContent = 'Send Message';
              submitBtn.disabled = false;
              contactForm.reset();

              setTimeout(function() {
                formStatus.className = 'form-status';
                formStatus.textContent = '';
              }, 5000);
            }, function(error) {
              formStatus.textContent = 'Failed to send msg. Check config.';
              formStatus.className = 'form-status error';
              submitBtn.textContent = 'Send Message';
              submitBtn.disabled = false;
              console.log('EmailJS Error:', error);
            });
        });
      }
    })();
  </script>

  <style>
    :global(:root) {
      --ease-smooth: cubic-bezier(0.22, 1, 0.36, 1);
      --ease-card: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-link: cubic-bezier(0.25, 0.8, 0.25, 1);
      --ease-photo: cubic-bezier(0.2, 0.75, 0.25, 1.15);
      --ease-hover-strong: cubic-bezier(0.2, 0.82, 0.2, 1);
      --c-violet: #8B5CF6;
      --c-pink: #EC4899;
      --c-yellow: #FACC15;
      --c-green: #4ADE80;
      --c-dark: #0F172A;
      --c-bg: #FAF9F6;
    }

    :global(body) {
      margin: 0;
      font-family: "Outfit", sans-serif;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
      background-color: var(--c-bg);
      background-image: 
        radial-gradient(#CBD5E1 2px, transparent 2px),
        radial-gradient(#CBD5E1 1px, transparent 1px);
      background-size: 32px 32px, 16px 16px;
      background-position: 0 0, 16px 16px;
      color: var(--c-dark);
    }

    :global(body)::before,
    :global(body)::after {
      content: "";
      position: absolute;
      pointer-events: none;
      z-index: -1;
    }

    :global(body)::before {
      top: 40px;
      right: -60px;
      width: 250px;
      height: 250px;
      background-color: var(--c-yellow);
      border: 4px solid var(--c-dark);
      border-radius: 50%;
      opacity: 0.15;
    }

    :global(body)::after {
      bottom: 80px;
      left: -80px;
      width: 300px;
      height: 300px;
      background-color: var(--c-pink);
      border: 4px solid var(--c-dark);
      transform: rotate(25deg);
      opacity: 0.15;
    }

    :global(*) {
      box-sizing: border-box;
    }

    :global(a) {
      color: inherit;
      text-decoration: none;
    }

    .page {
      max-width: 1120px;
      margin: 0 auto;
      padding: 24px 20px 40px;
      position: relative;
      z-index: 1;
      perspective: 1100px;
    }

    .reveal {
      opacity: 1;
      transform: none;
    }

    .js-anim .reveal {
      opacity: 0;
      transform: translateY(14px);
      animation: reveal-up 1.35s var(--ease-smooth) forwards;
    }

    .reveal-delay-1 { animation-delay: 0.08s; }
    .reveal-delay-2 { animation-delay: 0.16s; }
    .reveal-delay-3 { animation-delay: 0.26s; }
    .reveal-delay-4 { animation-delay: 0.36s; }
    .reveal-delay-5 { animation-delay: 0.46s; }
    .reveal-delay-6 { animation-delay: 0.56s; }
    .reveal-delay-7 { animation-delay: 0.66s; }

    .js-anim .section-animate {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.55s var(--ease-smooth), transform 0.6s var(--ease-smooth);
      transition-delay: var(--stagger, 0ms);
      will-change: opacity, transform;
    }

    .js-anim .section-animate.in-view {
      opacity: 1;
      transform: translateY(0);
    }

    .topbar {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      padding-bottom: 28px;
      transition: transform 0.55s var(--ease-link);
    }

    .topbar:hover {
      transform: translateY(-2px);
    }

    .eyebrow,
    .section-label,
    .kicker,
    .subtle,
    .terminal,
    .simple-list,
    .timeline-card p,
    .project-item p,
    .footer {
      font-family: "JetBrains Mono", monospace;
    }

    .eyebrow {
      margin: 0;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .subtle {
      margin: 6px 0 0;
      color: rgba(15, 23, 42, 0.5);
      font-size: 0.8rem;
    }

    .right {
      text-align: right;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(240px, 0.85fr);
      gap: 28px;
      align-items: center;
      padding: 24px 0 40px;
      transform-style: preserve-3d;
    }

    .hero-copy {
      position: relative;
      margin: -16px;
      padding: 16px;
      border-radius: 16px;
      border: 2px solid transparent;
      transition: transform 0.3s var(--ease-card), box-shadow 0.3s var(--ease-card), background 0.3s var(--ease-card), border-color 0.3s var(--ease-card);
    }

    .hero-copy:hover {
      transform: translateY(-6px) scale(1.01);
      background: #FFFFFF;
      border-color: var(--c-dark);
      box-shadow: 12px 12px 0px rgba(15, 23, 42, 1);
    }

    .hero-copy::before {
      content: "";
      position: absolute;
      top: -2px; left: -2px; right: -2px; bottom: -2px;
      border-radius: 16px;
      border: 2px solid var(--c-pink);
      opacity: 0;
      transform: scale(0.98);
      transition: opacity 0.3s ease, transform 0.3s ease;
      pointer-events: none;
      z-index: 10;
    }

    .hero-copy:hover::before {
      opacity: 1;
      transform: scale(1.025);
    }

    .hero-copy h1 {
      margin: 8px 0 0;
      font-family: "Syne", sans-serif;
      font-size: clamp(3rem, 8vw, 5.8rem);
      line-height: 0.95;
      letter-spacing: -0.05em;
    }

    .kicker {
      margin: 0;
      color: var(--c-violet);
      font-weight: 700;
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
    }

    .lead {
      margin: 18px 0 0;
      max-width: 62ch;
      font-size: 1.08rem;
      line-height: 1.75;
      color: rgba(15, 23, 42, 0.75);
    }

    .terminal {
      margin: 18px 0 0;
      color: rgba(15, 23, 42, 0.65);
      font-size: 0.95rem;
    }

    .terminal span {
      color: var(--c-pink);
      font-weight: bold;
    }

    .cursor {
      animation: blink 1s step-end infinite;
    }

    .links {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
      margin-top: 24px;
    }

    .links a {
      position: relative;
      overflow: hidden;
      padding: 10px 20px;
      border-radius: 999px;
      border: 2px solid var(--c-dark);
      background: #FFFFFF;
      color: var(--c-dark);
      font-weight: 600;
      box-shadow: 4px 4px 0px rgba(15, 23, 42, 1);
      transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
    }

    .links a:nth-child(1) { background: var(--c-pink); color: #fff; }
    .links a:nth-child(2) { background: var(--c-yellow); }
    .links a:nth-child(3) { background: var(--c-green); }
    .links a:nth-child(4) { background: var(--c-violet); color: #fff; }

    .links a:hover {
      transform: translateY(-4px);
      box-shadow: 6px 8px 0px rgba(15, 23, 42, 1);
      filter: brightness(1.05);
    }

    .links a:active {
      transform: translateY(2px);
      box-shadow: 2px 2px 0px rgba(15, 23, 42, 1);
    }

    .contact-inline-container {
      margin-top: 16px;
      min-height: 24px;
    }
    
    .inline-contact {
      display: none;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--c-violet);
      background: #FFFFFF;
      border: 2px solid var(--c-dark);
      border-radius: 8px;
      padding: 8px 16px;
      width: fit-content;
      box-shadow: 4px 4px 0px rgba(15, 23, 42, 1);
      animation: pop-in 0.25s var(--ease-card) forwards;
    }
    
    .inline-contact.active {
      display: inline-block;
    }

    @keyframes pop-in {
      from { opacity: 0; transform: translateY(-8px) scale(0.95); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .profile-card {
      position: relative;
      justify-self: end;
      width: min(100%, 360px);
      aspect-ratio: 1 / 1;
      padding: 14px;
      border-radius: 12px;
      background: #FFFFFF;
      border: 4px solid var(--c-dark);
      box-shadow: 12px 12px 0px var(--c-dark);
      isolation: isolate;
    }

    .js-anim .profile-pop.reveal {
      animation: reveal-up 1.28s var(--ease-photo) forwards;
    }

    .profile-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      border-radius: 6px;
      border: 2px solid var(--c-dark);
      filter: grayscale(100%);
      transition: filter 0.4s ease;
    }

    .profile-card:hover img {
      filter: grayscale(0%);
    }

    .section-grid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 28px;
      align-items: stretch;
    }

    .card {
      position: relative;
      grid-column: span 6;
      padding: 24px;
      border-radius: 16px;
      border: 2px solid var(--c-dark);
      background: #FFFFFF;
      box-shadow: 8px 8px 0px rgba(15, 23, 42, 1);
    }

    .wide {
