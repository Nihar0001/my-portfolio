---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nihar Narvekar | Full Stack & AI/ML Developer"
  description="Nihar Narvekar is a Full Stack Developer focused on backend systems, REST APIs, and AI-driven applications."
>
  <main class="page">
    <header class="topbar reveal reveal-delay-1">
      <div>
        <p class="eyebrow">Nihar Narvekar</p>
        <p class="subtle">Full Stack Developer · AI/ML Engineer</p>
      </div>
      <p class="subtle right">Pachal, Ratnagiri</p>
    </header>

    <section class="hero">
      <div class="hero-copy">
        <p class="kicker reveal reveal-delay-2">Backend Developer Intern at Pleximus Inc.</p>
        <h1 class="reveal reveal-delay-3">Nihar Narvekar</h1>
        <p class="lead reveal reveal-delay-4">
          Full Stack Developer with hands-on experience in Laravel, Flask, REST API development, PostgreSQL, MySQL,
          and AI/ML projects focused on computer vision and predictive modeling.
        </p>

        <p class="terminal reveal reveal-delay-5">
          <span>$</span> shipping CRM workflows, real-time apps, and ML pipelines<span class="cursor">_</span>
        </p>

        <div class="links reveal reveal-delay-6">
          <a href="https://github.com/Nihar0001" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://www.linkedin.com/in/nihar-narvekar-professional/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="mailto:narvekarnihar2204@gmail.com">Email</a>
          <a href="tel:+919422512747">Call</a>
        </div>
      </div>

      <div class="profile-card profile-pop reveal reveal-delay-4">
        <img src="/profile.jpg" alt="Nihar Narvekar" />
      </div>
    </section>

    <section class="section-grid">
      <article class="card wide reveal reveal-delay-2">
        <p class="section-label">Summary</p>
        <p>
          I build scalable backend systems, clean REST APIs, and practical AI solutions. My recent work includes CRM
          backend development, workflow automation, real-time object detection, and medical / agricultural ML pipelines.
        </p>
      </article>

      <article class="card reveal reveal-delay-3">
        <p class="section-label">Skills</p>
        <ul class="tag-list">
          <li>Flask</li>
          <li>Laravel</li>
          <li>REST APIs</li>
          <li>PostgreSQL</li>
          <li>MySQL</li>
          <li>MongoDB</li>
          <li>React.js</li>
          <li>System Design</li>
          <li>Computer Vision</li>
          <li>Predictive Modeling</li>
        </ul>
      </article>

      <article class="card wide reveal reveal-delay-4">
        <p class="section-label">Experience</p>
        <div class="list-block">
          <h3>Pleximus Inc. · Backend Developer Intern</h3>
          <p>Feb 2026 - Present · Building CRM backend, APIs, and async workflows with Laravel and PostgreSQL.</p>
        </div>
        <div class="list-block">
          <h3>InLighnX Global Pvt. Ltd. · AI & ML Intern</h3>
          <p>Nov 2025 - Dec 2025 · Optimized production-ready deep learning models for navigation and diagnostics.</p>
        </div>
        <div class="list-block">
          <h3>Innovate · AI & ML Intern</h3>
          <p>Jul 2025 - Aug 2025 · Completed real-time object detection project using SSD.</p>
        </div>
        <div class="list-block">
          <h3>Feynn Labs · Data Science Intern</h3>
          <p>May 2025 - Jul 2025 · Applied machine learning and data analysis to real-world datasets.</p>
        </div>
      </article>

      <article class="card wide reveal reveal-delay-5 projects-card">
        <p class="section-label">Projects</p>
        <div class="list-block project-item">
          <h3>Hybrid Diabetic Retinopathy Detection</h3>
          <p>CNN + ML hybrid classifier trained on 10,000+ images, achieving 92% accuracy and Android APK deployment.</p>
          <a class="project-link" href="https://github.com/Nihar0001?tab=repositories" target="_blank" rel="noopener noreferrer">View GitHub Repo</a>
        </div>
        <div class="list-block project-item">
          <h3>Smart Crop Advisor</h3>
          <p>CNN-based crop recommendation model improved accuracy by around 20% after tuning and augmentation.</p>
          <a class="project-link" href="https://github.com/Nihar0001?tab=repositories" target="_blank" rel="noopener noreferrer">View GitHub Repo</a>
        </div>
        <div class="list-block project-item">
          <h3>Facial Recognition Attendance System</h3>
          <p>Python, OpenCV, and Flask attendance system with 98% recognition accuracy and automated daily logs.</p>
          <a class="project-link" href="https://github.com/Nihar0001?tab=repositories" target="_blank" rel="noopener noreferrer">View GitHub Repo</a>
        </div>
      </article>

      <article class="card reveal reveal-delay-6">
        <p class="section-label">Education</p>
        <div class="list-block">
          <h3>RMCET, Ambav</h3>
          <p>B.E. · Mumbai University · Nov 2022 - Present · CGPA ~8.2 / 10.0</p>
        </div>
        <div class="list-block">
          <h3>SV. & Jr. College, Pachal</h3>
          <p>HSC · Jul 2021 - May 2022 · 75 / 100</p>
        </div>
      </article>

      <article class="card reveal reveal-delay-7">
        <p class="section-label">Certifications</p>
        <ul class="simple-list">
          <li>IBM Skills Build - AI Agent Architect</li>
          <li>Crio.Do - Netflix Trends Analysis</li>
          <li>Forage - Deloitte Australia Data Analytics</li>
          <li>Forage - JPMorgan Quantitative Research</li>
        </ul>
      </article>
    </section>

    <footer class="footer">
      <p>Nihar Narvekar · 2026</p>
    </footer>
  </main>

  <style>
    :global(:root) {
      --ease-smooth: cubic-bezier(0.22, 1, 0.36, 1);
      --ease-pop: cubic-bezier(0.18, 0.89, 0.32, 1.2);
      --ease-card: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-link: cubic-bezier(0.25, 0.8, 0.25, 1);
      --ease-photo: cubic-bezier(0.2, 0.75, 0.25, 1.15);
    }

    :global(body) {
      margin: 0;
      font-family: "Outfit", sans-serif;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
      background:
        radial-gradient(circle at top, rgba(125, 211, 196, 0.16), transparent 26%),
        radial-gradient(circle at bottom right, rgba(168, 85, 247, 0.14), transparent 22%),
        #060606;
      color: #f5f5f5;
    }

    :global(body)::before,
    :global(body)::after {
      content: "";
      position: fixed;
      width: 340px;
      height: 340px;
      border-radius: 50%;
      filter: blur(52px);
      opacity: 0.22;
      pointer-events: none;
      z-index: 0;
      transform: translateZ(0);
      animation: orb-drift 12s ease-in-out infinite;
    }

    :global(body)::before {
      top: -120px;
      right: -80px;
      background: radial-gradient(circle, rgba(125, 211, 196, 0.5), transparent 65%);
    }

    :global(body)::after {
      left: -110px;
      bottom: -120px;
      background: radial-gradient(circle, rgba(168, 85, 247, 0.5), transparent 65%);
      animation-delay: 2.2s;
    }

    :global(*) {
      box-sizing: border-box;
    }

    :global(a) {
      color: inherit;
      text-decoration: none;
    }

    .page {
      max-width: 1120px;
      margin: 0 auto;
      padding: 24px 20px 40px;
      position: relative;
      z-index: 1;
      perspective: 1100px;
    }

    .reveal {
      opacity: 0;
      transform: translateY(20px);
      animation: reveal-up 1.15s var(--ease-smooth) forwards;
    }

    .reveal-delay-1 { animation-delay: 0.08s; }
    .reveal-delay-2 { animation-delay: 0.16s; }
    .reveal-delay-3 { animation-delay: 0.26s; }
    .reveal-delay-4 { animation-delay: 0.36s; }
    .reveal-delay-5 { animation-delay: 0.46s; }
    .reveal-delay-6 { animation-delay: 0.56s; }
    .reveal-delay-7 { animation-delay: 0.66s; }

    .topbar {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      padding-bottom: 28px;
      transition: transform 0.55s var(--ease-link);
    }

    .topbar:hover {
      transform: translateY(-2px);
    }

    .eyebrow,
    .section-label,
    .kicker,
    .subtle,
    .terminal,
    .simple-list,
    .list-block p,
    .footer {
      font-family: "JetBrains Mono", monospace;
    }

    .eyebrow {
      margin: 0;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .subtle {
      margin: 6px 0 0;
      color: rgba(245, 245, 245, 0.62);
      font-size: 0.8rem;
    }

    .right {
      text-align: right;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(240px, 0.85fr);
      gap: 28px;
      align-items: center;
      padding: 24px 0 40px;
      transform-style: preserve-3d;
    }

    .hero-copy h1 {
      margin: 8px 0 0;
      font-family: "Syne", sans-serif;
      font-size: clamp(3rem, 8vw, 5.8rem);
      line-height: 0.95;
      letter-spacing: -0.05em;
    }

    .kicker {
      margin: 0;
      color: #7dd3c4;
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
    }

    .lead {
      margin: 18px 0 0;
      max-width: 62ch;
      font-size: 1.08rem;
      line-height: 1.75;
      color: rgba(245, 245, 245, 0.78);
    }

    .terminal {
      margin: 18px 0 0;
      color: rgba(245, 245, 245, 0.68);
      font-size: 0.95rem;
    }

    .terminal span {
      color: #7dd3c4;
    }

    .cursor {
      animation: blink 1s step-end infinite;
    }

    .links {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
      margin-top: 24px;
    }

    .links a {
      position: relative;
      overflow: hidden;
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.04);
      color: rgba(245, 245, 245, 0.9);
      transition: transform 0.58s var(--ease-link), border-color 0.48s var(--ease-link), color 0.45s var(--ease-link), background 0.52s var(--ease-link), box-shadow 0.58s var(--ease-link);
    }

    .links a::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 20%, rgba(255, 255, 255, 0.16) 45%, transparent 70%);
      transform: translateX(-120%);
      transition: transform 0.95s var(--ease-smooth);
    }

    .links a:hover {
      border-color: rgba(125, 211, 196, 0.4);
      color: #7dd3c4;
      background: rgba(255, 255, 255, 0.07);
      transform: translateY(-2px) translateZ(8px);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.26);
    }

    .links a:hover::before {
      transform: translateX(120%);
    }

    .profile-card {
      justify-self: end;
      width: min(100%, 360px);
      aspect-ratio: 1 / 1;
      padding: 14px;
      border-radius: 28px;
      background: linear-gradient(145deg, rgba(125, 211, 196, 0.16), rgba(168, 85, 247, 0.16));
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
      transform-style: preserve-3d;
      animation: card-float 7.2s ease-in-out infinite;
      transition: transform 0.75s var(--ease-photo), box-shadow 0.72s var(--ease-photo), border-color 0.58s var(--ease-photo);
    }

    .profile-pop.reveal {
      animation: photo-pop-3d 1.28s var(--ease-photo) forwards;
    }

    .profile-card:hover {
      transform: translateY(-10px) rotateX(5deg) rotateY(-5deg) scale(1.012);
      border-color: rgba(125, 211, 196, 0.42);
      box-shadow: 0 30px 95px rgba(0, 0, 0, 0.44), 0 0 0 1px rgba(125, 211, 196, 0.2);
    }

    .profile-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: transform 0.85s var(--ease-photo), filter 0.72s var(--ease-photo);
    }

    .profile-card:hover img {
      transform: scale(1.045) rotate(0.4deg);
      filter: saturate(1.06) contrast(1.04);
    }

    .section-grid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 18px;
      align-items: stretch;
    }

    .card {
      position: relative;
      overflow: hidden;
      grid-column: span 6;
      padding: 20px;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(12px);
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.22);
      transform-style: preserve-3d;
      transition: transform 0.66s var(--ease-card), border-color 0.62s var(--ease-card), box-shadow 0.68s var(--ease-card), background 0.6s var(--ease-card);
    }

    .card::before {
      content: "";
      position: absolute;
      inset: -1px;
      background: linear-gradient(120deg, transparent 35%, rgba(125, 211, 196, 0.14) 50%, transparent 65%);
      transform: translateX(-125%);
      transition: transform 1.08s var(--ease-smooth);
      pointer-events: none;
    }

    .card:hover {
      transform: translateY(-8px) rotateX(3deg) rotateY(-2deg);
      border-color: rgba(125, 211, 196, 0.35);
      background: rgba(255, 255, 255, 0.06);
      box-shadow: 0 28px 80px rgba(0, 0, 0, 0.34);
    }

    .card:hover::before {
      transform: translateX(125%);
    }

    .wide {
      grid-column: span 12;
    }

    .section-label {
      margin: 0 0 12px;
      color: rgba(125, 211, 196, 0.9);
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
    }

    .card p,
    .card li {
      color: rgba(245, 245, 245, 0.76);
      line-height: 1.7;
    }

    .card h3 {
      margin: 0 0 6px;
      font-family: "Syne", sans-serif;
      font-size: 1.05rem;
      line-height: 1.3;
    }

    .tag-list,
    .simple-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .tag-list li {
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.03);
      color: rgba(245, 245, 245, 0.92);
      font-size: 0.92rem;
      transition: transform 0.46s var(--ease-link), border-color 0.44s var(--ease-link), color 0.44s var(--ease-link), background 0.44s var(--ease-link);
    }

    .tag-list li:hover {
      transform: translateY(-2px);
      border-color: rgba(125, 211, 196, 0.35);
      color: #ffffff;
      background: rgba(125, 211, 196, 0.08);
    }

    .simple-list {
      flex-direction: column;
      gap: 12px;
    }

    .simple-list li {
      padding-left: 14px;
      border-left: 2px solid rgba(125, 211, 196, 0.45);
      transition: border-color 0.48s var(--ease-card), transform 0.48s var(--ease-card), color 0.48s var(--ease-card);
    }

    .simple-list li:hover {
      transform: translateX(3px);
      border-left-color: rgba(168, 85, 247, 0.8);
    }

    .list-block + .list-block {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .project-item {
      position: relative;
      border-radius: 14px;
      padding: 6px 10px 10px;
      transition: transform 0.6s var(--ease-card), background 0.54s var(--ease-card), box-shadow 0.58s var(--ease-card);
    }

    .projects-card .project-item {
      opacity: 0;
      transform: translateY(14px) scale(0.985);
      animation: project-pop 1.05s var(--ease-pop) forwards;
    }

    .projects-card .project-item:nth-of-type(1) { animation-delay: 0.26s; }
    .projects-card .project-item:nth-of-type(2) { animation-delay: 0.42s; }
    .projects-card .project-item:nth-of-type(3) { animation-delay: 0.58s; }

    .project-item:hover {
      transform: translateX(4px) translateY(-2px);
      background: rgba(255, 255, 255, 0.04);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
    }

    .project-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 10px;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(125, 211, 196, 0.96);
      position: relative;
      transition: color 0.48s var(--ease-link), transform 0.48s var(--ease-link), letter-spacing 0.48s var(--ease-link);
    }

    .project-link::before {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: -2px;
      height: 1px;
      background: currentColor;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.48s var(--ease-link);
    }

    .project-link::after {
      content: "→";
      display: inline-block;
      transition: transform 0.25s ease;
    }

    .project-link:hover {
      color: #ffffff;
      letter-spacing: 0.11em;
      transform: translateX(3px);
    }

    .project-link:hover::before {
      transform: scaleX(1);
    }

    .project-link:hover::after {
      transform: translateX(3px);
    }

    .project-link:visited {
      color: rgba(168, 85, 247, 0.92);
    }

    .project-link:focus-visible {
      outline: 2px solid rgba(125, 211, 196, 0.8);
      outline-offset: 4px;
      border-radius: 6px;
    }

    .list-block p {
      margin: 0;
      font-size: 0.92rem;
      color: rgba(245, 245, 245, 0.68);
    }

    .footer {
      padding-top: 26px;
      text-align: center;
      color: rgba(245, 245, 245, 0.48);
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    @keyframes blink {
      0%, 50% { opacity: 1; }
      51%, 100% { opacity: 0; }
    }

    @keyframes reveal-up {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes orb-drift {
      0%,
      100% {
        transform: translate3d(0, 0, 0) scale(1);
      }
      50% {
        transform: translate3d(0, -18px, 0) scale(1.08);
      }
    }

    @keyframes card-float {
      0%,
      100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-3px);
      }
    }

    @keyframes project-pop {
      0% {
        opacity: 0;
        transform: translateY(14px) scale(0.985);
      }
      65% {
        opacity: 1;
        transform: translateY(-3px) scale(1.01);
      }
      100% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes photo-pop-3d {
      0% {
        opacity: 0;
        transform: translateY(28px) rotateX(11deg) rotateY(-8deg) scale(0.94);
      }
      62% {
        opacity: 1;
        transform: translateY(-6px) rotateX(2deg) rotateY(-1deg) scale(1.015);
      }
      100% {
        opacity: 1;
        transform: translateY(0) rotateX(0) rotateY(0) scale(1);
      }
    }

    @media (max-width: 900px) {
      .hero {
        grid-template-columns: 1fr;
        gap: 20px;
      }

      .profile-card {
        justify-self: center;
        width: min(100%, 320px);
      }

      .card,
      .wide {
        grid-column: span 12;
      }

      .profile-card,
      .card {
        animation: none;
      }
    }

    @media (max-width: 640px) {
      .page {
        padding-inline: 16px;
      }

      .topbar {
        align-items: flex-start;
        flex-direction: column;
      }

      .right {
        text-align: left;
      }

      .links a {
        width: 100%;
        text-align: center;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal,
      .projects-card .project-item,
      .profile-card,
      .cursor,
      :global(body)::before,
      :global(body)::after {
        animation: none !important;
      }

      .reveal,
      .projects-card .project-item {
        opacity: 1 !important;
        transform: none !important;
      }

      .card,
      .project-item,
      .project-link,
      .links a,
      .tag-list li,
      .simple-list li,
      .profile-card img {
        transition: none !important;
      }
    }
  </style>
</BaseLayout>
