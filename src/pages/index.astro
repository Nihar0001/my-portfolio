      font-size: 0.92rem;
      text-align: center;
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
      box-shadow: 3px 3px 0px rgba(15, 23, 42, 1);
    }

    .simple-list {
      flex-direction: column;
      gap: 12px;
    }

    .simple-list li {
      position: relative;
      padding: 12px 16px;
      border-radius: 8px;
      border: 2px solid var(--c-dark);
      background: #FFFFFF;
      box-shadow: 3px 3px 0px rgba(15, 23, 42, 1);
