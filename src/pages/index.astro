    .chip-list li:nth-child(even) { background-color: #F8FAFC; border-color: var(--c-violet); color: var(--c-violet); }
    .chip-list li:nth-child(3n) { background-color: #FFFBEB; border-color: var(--c-yellow); color: #B45309; }
    .chip-list li:nth-child(4n) { background-color: #FDF2F8; border-color: var(--c-pink); color: var(--c-pink); }
