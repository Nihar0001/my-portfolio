    @keyframes blink {
      0%, 50% { opacity: 1; }
      51%, 100% { opacity: 0; }
    }

    @keyframes reveal-up {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes orb-drift {
      0%,
      100% {
        transform: translate3d(0, 0, 0) scale(1);
      }
      50% {
        transform: translate3d(0, -18px, 0) scale(1.08);
      }
    }

    @keyframes profile-hover-pop {
      0% {
        transform: translateY(0) scale(1);
      }
      62% {
        transform: translateY(-11px) scale(1.055);
      }
      100% {
        transform: translateY(-9px) scale(1.045);
      }
    }

    @keyframes profile-ring-pop {
      0% {
        opacity: 0;
        transform: scale(0.9);
        box-shadow: 0 0 0 0 rgba(125, 211, 196, 0.16);
      }
      55% {
        opacity: 0.42;
        transform: scale(1.012);
        box-shadow: 0 0 0 7px rgba(125, 211, 196, 0.09);
      }
      100% {
        opacity: 0.28;
        transform: scale(1.006);
        box-shadow: 0 0 0 4px rgba(125, 211, 196, 0.05);
      }
    }

    @keyframes photo-pop-3d {
      0% {
        opacity: 0;
        transform: translateY(28px) rotateX(11deg) rotateY(-8deg) scale(0.94);
      }
      62% {
        opacity: 1;
        transform: translateY(-6px) rotateX(2deg) rotateY(-1deg) scale(1.015);
      }
      100% {
        opacity: 1;
        transform: translateY(0) rotateX(0) rotateY(0) scale(1);
      }
    }

